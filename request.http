### User register
POST http://localhost:4000/user-api/users
Content-Type: application/json

{
    "firstName":"pavanika",
    "lastName":"minukuri",
    "email":"pavanika.user@example.com",
    "password":"User@12345",
    "profileImageUrl":"https://example.com.avatars.author.png"
}

### User Login
POST http://localhost:4000/common-api/login
Content-Type: application/json

{
  "email": "pavanika.user@example.com",
  "password": "User@12345"
 
}

### read all articles by user
GET http://localhost:4000/user-api/articles

### add comment to an article by user
PUT http://localhost:4000/user-api/articles
Content-Type: application/json

{
    "user":"69aedcfde1032a43f31faec0",
    "articleId":"69aedd86e1032a43f31faecc",
    "comment":"Good article."
}






### Author register
POST http://localhost:4000/author-api/users
Content-Type: application/json

{
    "firstName":"varshith",
    "lastName":"inupamula",
    "email":"varshith.author@example.com",
    "password":"Author@12345",
    "profileImageUrl":"https://example.com.avatars.author.png"
}

### Author Login
POST http://localhost:4000/common-api/login
Content-Type: application/json

{
    "email":"varshith.author@example.com",
    "password":"Author@12345"
}

###  create articles (AUTHOR)
POST http://localhost:4000/author-api/articles
Content-Type: application/json

{
    "author":"69aedd3fe1032a43f31faec4",
    "title":"Article 3",
    "category":"SQL",
    "content":"content of article 3"
}


### Read articles of author
GET http://localhost:4000/author-api/articles/69aedd3fe1032a43f31faec4


###  update articles
PUT http://localhost:4000/author-api/articles
Content-Type: application/json

{
    "author":"69aedd3fe1032a43f31faec4",
    "articleId":"69aedd86e1032a43f31faecc",
    "title":"Article 2",
    "category":"programming",
    "content":"content of article 2 updated"
}

### delete an article
PATCH  http://localhost:4000/author-api/articles/69aedd50e1032a43f31faec7/status
Content-Type: application/json

{
    "isArticleActive":false
}






### read all articles by admin
GET http://localhost:4000/admin-api/articles


### block user roles
POST http://localhost:4000/admin-api/block-user
Content-Type: application/json

{
    "userId":"698dfcaa90cb51bc33da882b",
    "role":"author"
}

### unblock user roles
POST http://localhost:4000/admin-api/unblock-user
Content-Type: application/json

{
    "userId":"69896dbf9342acaad0d14923",
    "role":"author"
}


### change password
PUT http://localhost:4000/common-api/change-password
Content-Type: application/json

{
    "email":"pavanika.user@example.com",
    "currentPassword":"User@12345",
    "newPassword":"pavu15"
}



### logout
POST  http://localhost:4000/common-api/logout


### Test res
GET http://localhost:4000/test
